# Backend settings
APP_NAME=methodology-backend
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=methodology
POSTGRES_USER=methodology
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://methodology:change_me@postgres:5432/methodology

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=21600
JWT_SECRET_FILE=/run/secrets/jwt_secret

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=methodology
KEYCLOAK_CLIENT_ID=backend
KEYCLOAK_CLIENT_SECRET=change_me

# Magic Link
MAGIC_LINK_TTL_SECONDS=86400

# Redis
REDIS_URL=redis://redis:6379/0
PERMISSIONS_CACHE_TTL_SECONDS=600

# Scheduler
SYNC_INTERVAL_SECONDS=120
SYNC_MAX_RETRIES=5

# Security and CORS
CORS_ALLOW_ORIGINS=http://localhost:5173
RATE_LIMIT_LOGIN=5/minute

# Encryption
MASTER_KEY_SECRET_FILE=/run/secrets/master_key
