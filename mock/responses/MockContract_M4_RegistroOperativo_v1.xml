<?xml version="1.0" encoding="UTF-8"?>
<!--
  MockContract – Módulo 4: Registro Operativo
  Sistema de Registro Metodológico de Métricas Lingüísticas
  Versión: 1.0  |  Fecha: 2026-03-12  |  Estado: En revisión
-->

<mockModuleContract module="OperationalRegistry" version="1.0">

    <moduleInfo>
        <n>Anonymized Operational Registry</n>
        <description>
            Captura estructurada y trazable de los datos derivados de la aplicación de
            instrumentos metodológicos a sujetos de estudio. Opera bajo los principios
            de anonimización (UUID como único identificador), minimización (solo datos
            necesarios) y separación de identidad (sin PII en ninguna entidad).

            Flujo completo del módulo:
              1. POST /subjects          → registrar sujeto MOCK con UUID
              2. POST /subjects/{id}/context → agregar datos contextuales no identificables
              3. POST /applications      → registrar aplicación (sujeto + instrumento activo)
              4. POST /metric-values     → capturar valores de métricas de la aplicación

            Depende de M1 (autenticación), M2 (instrumentos activos y vigentes)
            y M3 (métricas y sus reglas de validación).
            Solo el rol Profesional Aplicador (y Administrador) pueden operar este módulo.
        </description>
        <owner>Equipo de Desarrollo – Módulo 4</owner>
        <basePath>/api/v1</basePath>
    </moduleInfo>

    <endpoints>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- RF-M4-01 · HU14 – Registrar sujeto anonimizado             -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <endpoint id="RF-M4-01">
            <n>Create Subject</n>
            <method>POST</method>
            <path>/subjects</path>
            <description>
                Registra un sujeto MOCK generando automáticamente un UUID como único
                identificador. No se almacena ningún dato personal identificable (nombre,
                CURP, dirección, etc.). El UUID es el único vínculo entre el sujeto y
                sus aplicaciones. Solo accesible por Profesional Aplicador y Administrador.
            </description>
            <request>
                <headers>
                    <header name="Content-Type">application/json</header>
                    <header name="Authorization">Bearer {jwt_token}</header>
                </headers>
                <body>
                    <!-- El body DEBE estar vacío o ausente.
                         Cualquier campo enviado, independientemente de su nombre o valor,
                         resulta en HTTP 400. Privacy by Design: el sistema rechaza
                         activamente cualquier intento de enviar datos no declarados. -->
                </body>
            </request>
            <responses>
                <response status="201">
                    <description>Sujeto registrado exitosamente con UUID generado</description>
                    <body>
                        <field name="status"  type="string" description="success"/>
                        <field name="message" type="string" description="Subject registered successfully"/>
                        <field name="data"    type="object">
                            <field name="id"         type="string"   description="UUID generado automáticamente para el sujeto"/>
                            <field name="created_at" type="datetime"/>
                        </field>
                    </body>
                </response>
                <response status="400">
                    <description>
                        El body contiene campos. Privacy by Design (AD-09): el endpoint no acepta
                        ningún campo en el body. Cualquier campo enviado es rechazado activamente
                        con 400 independientemente de su nombre o valor.
                    </description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Request body must be empty"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="401">
                    <description>Token JWT ausente o inválido</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Unauthorized"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="403">
                    <description>Rol sin permisos (solo Aplicador y Administrador)</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Forbidden: insufficient role permissions"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
            </responses>
        </endpoint>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- RF-M4-02 · HU15 – Registrar contexto no identificable      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <endpoint id="RF-M4-02">
            <n>Register Subject Context</n>
            <method>POST</method>
            <path>/subjects/{id}/context</path>
            <description>
                Registra datos contextuales mínimos asociados a un sujeto existente.
                Ningún atributo permite identificar directa ni indirectamente al sujeto.
                El sistema valida que el sujeto exista antes de persistir el contexto.
                Se permiten múltiples atributos contextuales definidos metodológicamente.

                Atributos de contexto definidos por el equipo de investigación:
                  school_type       → tipo de escuela: public | private | unknown
                  education_level   → nivel educativo: preschool | primary_lower (1-3) |
                                      primary_upper (4-6) | secondary | unknown
                  age_cohort        → cohorte de edad: ej. "6-8" | "9-11" | "12-14" | "15-17"
                  gender            → género: male | female | non_binary | prefer_not_to_say
                  socioeconomic_level → nivel socioeconómico: low | medium | high | unknown
                  additional_attributes → objeto abierto para atributos metodológicos
                                          futuros no definidos aún (clave-valor libre)

                Solo accesible por Profesional Aplicador y Administrador.
            </description>
            <request>
                <headers>
                    <header name="Content-Type">application/json</header>
                    <header name="Authorization">Bearer {jwt_token}</header>
                </headers>
                <pathParams>
                    <param name="id" type="string" required="true" description="UUID del sujeto"/>
                </pathParams>
                <body>
                    <field name="school_type"           type="string" required="false" description="Tipo de escuela: public | private | unknown"/>
                    <field name="education_level"       type="string" required="false" description="Nivel educativo: preschool | primary_lower | primary_upper | secondary | unknown"/>
                    <field name="age_cohort"            type="string" required="false" description="Cohorte de edad como rango: ej. '6-8', '9-11', '12-14', '15-17'"/>
                    <field name="gender"                type="string" required="false" description="Género: male | female | non_binary | prefer_not_to_say"/>
                    <field name="socioeconomic_level"   type="string" required="false" description="Nivel socioeconómico: low | medium | high | unknown"/>
                    <field name="additional_attributes" type="object" required="false" description="Atributos metodológicos adicionales en formato clave-valor libre"/>
                </body>
            </request>
            <responses>
                <response status="201">
                    <description>Contexto registrado y vinculado al UUID del sujeto</description>
                    <body>
                        <field name="status"  type="string" description="success"/>
                        <field name="message" type="string" description="Context registered successfully"/>
                        <field name="data"    type="object">
                            <field name="id"                     type="string"   description="UUID del registro de contexto"/>
                            <field name="subject_id"             type="string"   description="UUID del sujeto asociado"/>
                            <field name="school_type"            type="string"/>
                            <field name="education_level"        type="string"/>
                            <field name="age_cohort"             type="string"/>
                            <field name="gender"                 type="string"/>
                            <field name="socioeconomic_level"    type="string"/>
                            <field name="additional_attributes"  type="object"   description="null si no se proporcionó"/>
                            <field name="created_at"             type="datetime"/>
                        </field>
                    </body>
                </response>
                <response status="400">
                    <description>
                        Datos inválidos. Posibles causas:
                        - school_type con valor fuera del enum permitido
                        - education_level con valor fuera del enum permitido
                        - gender con valor fuera del enum permitido
                        - socioeconomic_level con valor fuera del enum permitido
                        - age_cohort con formato inválido
                    </description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Descripción del error de validación"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="401">
                    <description>Token JWT ausente o inválido</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Unauthorized"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="403">
                    <description>Rol sin permisos</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Forbidden: insufficient role permissions"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="404">
                    <description>Sujeto no encontrado</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Subject not found"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
            </responses>
        </endpoint>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- RF-M4-03 · HU16 – Registrar aplicación de prueba           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <endpoint id="RF-M4-03">
            <n>Create Test Application</n>
            <method>POST</method>
            <path>/applications</path>
            <description>
                Registra la aplicación de un instrumento metodológico a un sujeto.
                El sistema valida:
                  - Que el sujeto exista (por UUID).
                  - Que el instrumento exista y esté en estado active.
                  - Que la fecha de aplicación esté dentro del periodo de vigencia
                    del instrumento (start_date ≤ application_date ≤ end_date).
                La fecha de aplicación se registra automáticamente con la fecha actual
                si no se proporciona explícitamente.
                Solo accesible por Profesional Aplicador y Administrador.
            </description>
            <request>
                <headers>
                    <header name="Content-Type">application/json</header>
                    <header name="Authorization">Bearer {jwt_token}</header>
                </headers>
                <body>
                    <field name="subject_id"       type="string" required="true"  description="UUID del sujeto registrado en el sistema"/>
                    <field name="instrument_id"    type="string" required="true"  description="UUID del instrumento a aplicar"/>
                    <field name="application_date" type="date"   required="false" description="Fecha de aplicación (ISO 8601: YYYY-MM-DD). Si se omite, se usa la fecha actual del servidor"/>
                    <field name="notes"            type="string" required="false" description="Notas operativas no identificables sobre la sesión de aplicación"/>
                </body>
            </request>
            <responses>
                <response status="201">
                    <description>Aplicación registrada exitosamente</description>
                    <body>
                        <field name="status"  type="string" description="success"/>
                        <field name="message" type="string" description="Application registered successfully"/>
                        <field name="data"    type="object">
                            <field name="id"               type="string"   description="UUID de la aplicación"/>
                            <field name="subject_id"       type="string"/>
                            <field name="instrument_id"    type="string"/>
                            <field name="application_date" type="date"/>
                            <field name="notes"            type="string"   description="null si no se proporcionó"/>
                            <field name="created_at"       type="datetime"/>
                        </field>
                    </body>
                </response>
                <response status="400">
                    <description>
                        Datos inválidos. Posibles causas:
                        - application_date con formato inválido
                        - application_date fuera del periodo de vigencia del instrumento
                    </description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Descripción del error; ej: application_date is outside the instrument validity period"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="401">
                    <description>Token JWT ausente o inválido</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Unauthorized"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="403">
                    <description>Rol sin permisos</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Forbidden: insufficient role permissions"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="404">
                    <description>Sujeto o instrumento no encontrado</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Subject not found | Instrument not found"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="422">
                    <description>Instrumento inactivo; no puede recibir nuevas aplicaciones</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Instrument is inactive and cannot receive new applications"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
            </responses>
        </endpoint>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- RF-M4-04 · HU17 – Capturar valores de métricas             -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <endpoint id="RF-M4-04">
            <n>Submit Metric Values</n>
            <method>POST</method>
            <path>/metric-values</path>
            <description>
                Registra el conjunto de valores de métricas obtenidos en una aplicación.
                El sistema valida para cada valor:
                  (1) Que la aplicación exista.
                  (2) Que la métrica pertenezca al instrumento de esa aplicación.
                  (3) Que el tipo de dato del valor coincida con metric_type.
                  (4) Que el valor esté dentro del rango [min_value, max_value] si metric_type = numeric.
                  (5) Que el valor esté dentro de options si metric_type = categorical.
                Adicionalmente valida que todas las métricas marcadas como required
                estén presentes en el envío. Si alguna validación falla, ningún valor
                se persiste (operación atómica).
                Solo accesible por Profesional Aplicador y Administrador.
            </description>
            <request>
                <headers>
                    <header name="Content-Type">application/json</header>
                    <header name="Authorization">Bearer {jwt_token}</header>
                </headers>
                <body>
                    <field name="application_id" type="string" required="true"  description="UUID de la aplicación a la que pertenecen los valores"/>
                    <field name="values"         type="array"  required="true"  description="Lista de valores de métricas">
                        <field name="metric_id"  type="string" required="true"  description="UUID de la métrica definida en M3"/>
                        <field name="value"      type="any"    required="true"  description="Valor capturado. Tipo según metric_type: number para numeric, string para categorical/short_text, boolean para boolean"/>
                    </field>
                </body>
            </request>
            <responses>
                <response status="201">
                    <description>Valores registrados exitosamente</description>
                    <body>
                        <field name="status"  type="string" description="success"/>
                        <field name="message" type="string" description="Metric values submitted successfully"/>
                        <field name="data"    type="object">
                            <field name="application_id"   type="string"/>
                            <field name="values_recorded"  type="integer" description="Número de valores persistidos"/>
                            <field name="values"           type="array">
                                <field name="id"        type="string"   description="UUID del registro MetricValue"/>
                                <field name="metric_id" type="string"/>
                                <field name="value"     type="any"/>
                            </field>
                        </field>
                    </body>
                </response>
                <response status="400">
                    <description>
                        Error de validación. La operación completa es rechazada. Posibles causas:
                        - Una o más métricas obligatorias no están incluidas en values[]
                        - Tipo de dato de un valor no coincide con metric_type de la métrica
                        - Valor numérico fuera del rango [min_value, max_value]
                        - Valor categórico no pertenece a options[]
                        - metric_id referencia una métrica que no pertenece al instrumento de la aplicación
                    </description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Descripción clara del error de validación"/>
                        <field name="data"    type="object" description="Detalle opcional de errores por métrica">
                            <field name="errors" type="array">
                                <field name="metric_id" type="string" description="UUID de la métrica que falló validación"/>
                                <field name="reason"    type="string" description="Descripción del error específico"/>
                            </field>
                        </field>
                    </body>
                </response>
                <response status="401">
                    <description>Token JWT ausente o inválido</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Unauthorized"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="403">
                    <description>Rol sin permisos</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Forbidden: insufficient role permissions"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="404">
                    <description>Aplicación no encontrada</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Application not found"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
            </responses>
        </endpoint>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Endpoint de soporte – Consultar sujeto por UUID             -->
        <!-- Necesario para verificar existencia antes de registrar      -->
        <!-- contexto o aplicación                                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <endpoint id="RF-M4-GET-SUBJECT">
            <n>Get Subject</n>
            <method>GET</method>
            <path>/subjects/{id}</path>
            <description>
                Devuelve los datos de un sujeto (UUID + contexto asociado si existe).
                No expone ningún dato personal identificable. Accesible por todos los
                roles autenticados.
            </description>
            <request>
                <headers>
                    <header name="Authorization">Bearer {jwt_token}</header>
                </headers>
                <pathParams>
                    <param name="id" type="string" required="true" description="UUID del sujeto"/>
                </pathParams>
            </request>
            <responses>
                <response status="200">
                    <description>Datos del sujeto y contexto asociado</description>
                    <body>
                        <field name="status"  type="string" description="success"/>
                        <field name="message" type="string" description="Subject retrieved"/>
                        <field name="data"    type="object">
                            <field name="id"         type="string"   description="UUID del sujeto"/>
                            <field name="created_at" type="datetime"/>
                            <field name="context"    type="object"   description="null si no se registró contexto">
                                <field name="school_type"           type="string"/>
                                <field name="education_level"       type="string"/>
                                <field name="age_cohort"            type="string"/>
                                <field name="gender"                type="string"/>
                                <field name="socioeconomic_level"   type="string"/>
                                <field name="additional_attributes" type="object"/>
                            </field>
                        </field>
                    </body>
                </response>
                <response status="401">
                    <description>Token JWT ausente o inválido</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Unauthorized"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
                <response status="404">
                    <description>Sujeto no encontrado</description>
                    <body>
                        <field name="status"  type="string" description="error"/>
                        <field name="message" type="string" description="Subject not found"/>
                        <field name="data"    type="null"/>
                    </body>
                </response>
            </responses>
        </endpoint>

    </endpoints>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Referencia de atributos contextuales (ContextData)             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <contextAttributes>
        <attribute name="school_type"         values="public | private | unknown"/>
        <attribute name="education_level"     values="preschool | primary_lower | primary_upper | secondary | unknown"
                                              notes="primary_lower = 1°-3°, primary_upper = 4°-6°"/>
        <attribute name="age_cohort"          values="string de rango libre, ej: '6-8' | '9-11' | '12-14' | '15-17'"
                                              notes="Se recomienda usar rangos de 2-3 años para anonimización efectiva"/>
        <attribute name="gender"              values="male | female | non_binary | prefer_not_to_say"/>
        <attribute name="socioeconomic_level" values="low | medium | high | unknown"/>
        <attribute name="additional_attributes" values="objeto JSON libre para atributos futuros no definidos aún"
                                              notes="Permite extensibilidad sin migración de esquema"/>
    </contextAttributes>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Reglas de validación de MetricValue (síntesis para mock)       -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <metricValueValidationRules>
        <rule metric_type="numeric"     validation="number; dentro de [min_value, max_value] si están definidos"/>
        <rule metric_type="categorical" validation="string; debe pertenecer a options[]"/>
        <rule metric_type="boolean"     validation="true | false"/>
        <rule metric_type="short_text"  validation="string; sin restricciones adicionales"/>
        <rule name="required_check"     validation="Todas las métricas con required=true deben estar presentes en values[]"/>
        <rule name="atomicity"          validation="Si cualquier validación falla, ningún MetricValue se persiste"/>
    </metricValueValidationRules>

</mockModuleContract>
